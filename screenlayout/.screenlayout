#!/bin/sh

HDMI_STATUS=$(xrandr | grep "HDMI-1 connected")

if [ -n "$HDMI_STATUS" ]; then
    xrandr \
        --output eDP-1 --mode 1920x1080 \
        --output HDMI-1 --mode 1920x1080 --primary --rate 120 --right-of eDP-1
else
    xrandr \
        --output eDP-1 --mode 1920x1080 --primary \
        --output HDMI-1 --off
fi
