#
# reload sxhkd
#

super + Escape
    pkill -USR1 sxhkd

#
# general/applications
#

super + p
    dmenu_run

super + shift + Return
    st

super + shift + e
    ~/.config/sxhkd/scripts/powermenu

super + shift + x
    slock -m "$(cowsay "$(fortune)")" 

#
# screenshots
#

Print
    maim ~/pics/screenshot-$(date +%s).png

shift + Print
    maim -s ~/pics/screenshot-$(date +%s).png

control + shift + Print
    maim -s | xclip -selection clipboard -t image/png

#
# audio & brightness
#

XF86AudioRaiseVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+

XF86AudioLowerVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-

XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

XF86AudioMicMute
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

XF86MonBrightnessUp
    brightnessctl set +5%

XF86MonBrightnessDown
    brightnessctl set 5%-

#
# media keys
#

XF86AudioPlay
    playerctl play-pause

XF86AudioNext
    playerctl next

XF86AudioPrev
    playerctl previous

#
# dwm focus
#

super + j
    dwm-msg run_command focusstack 1

super + k
    dwm-msg run_command focusstack -1

super + Return
    dwm-msg run_command zoom

super + shift + c
    dwm-msg run_command killclient


#
# master area
#

super + i
    dwm-msg run_command incnmaster 1

super + d
    dwm-msg run_command incnmaster -1

super + h
    dwm-msg run_command setmfact -0.05

super + l
    dwm-msg run_command setmfact 0.05


#
# layouts
#

super + t
    dwm-msg run_command setlayoutipc 0

super + f
    dwm-msg run_command setlayoutipc 1

super + m
    dwm-msg run_command setlayoutipc 2

super + shift + space
    dwm-msg run_command togglefloating
    
super + shift + f
    dwm-msg run_command togglefullscr

#
# bar
#

super + b
    dwm-msg run_command togglebar


#
# monitor controls
#

super + comma
    dwm-msg run_command focusmon -1

super + period
    dwm-msg run_command focusmon 1

super + shift + comma
    dwm-msg run_command tagmon -1

super + shift + period
    dwm-msg run_command tagmon 1


